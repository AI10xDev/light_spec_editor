# Azure OpenAI settings for the default SimpleEditor AI features.
# Copy to .env.local for local development. Do not commit real values.
VITE_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
VITE_AZURE_OPENAI_API_KEY=replace-with-local-development-key
VITE_AZURE_OPENAI_DEPLOYMENT=your-azure-openai-deployment
VITE_AZURE_OPENAI_API_VERSION=2024-10-21

# Optional Tiptap Cloud collaboration / Pro AI template settings.
# These are used by the Notion-like template code, not the default App.tsx mount.
VITE_TIPTAP_COLLAB_DOC_PREFIX=local-
VITE_TIPTAP_COLLAB_APP_ID=
VITE_TIPTAP_COLLAB_TOKEN=
VITE_TIPTAP_AI_APP_ID=
VITE_TIPTAP_AI_TOKEN=

# When set, token fetch helpers call /api/collaboration and /api/ai instead of
# reading static Tiptap tokens from VITE_* values.
VITE_USE_JWT_TOKEN_API_ENDPOINT=
